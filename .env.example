# HubSpot OAuth (create app at developers.hubspot.com)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3001/auth/hubspot/callback

# Backend
API_BASE_URL=http://localhost:3001
PORT=3001

# Widget (Vite) - base URL for API calls from the widget
VITE_API_BASE_URL=http://localhost:3001

# For production, use your deployed URLs:
# HUBSPOT_REDIRECT_URI=https://your-app.vercel.app/auth/hubspot/callback
# API_BASE_URL=https://your-app.vercel.app
